# Anthropic API key – get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default shown below)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Sentence-transformers model used for embeddings (default shown below)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Path to the biodata knowledge-base file (default shown below)
# BIODATA_PATH=data/biodata.md

# Maximum number of document chunks returned by the retriever
# TOP_K=5
